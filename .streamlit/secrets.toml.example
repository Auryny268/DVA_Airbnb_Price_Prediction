# Copy this file to `.streamlit/secrets.toml` and fill in the values.
# The real secrets.toml is gitignored — never commit it.

# Required: Anthropic API key used by the "Ask the Data" chat tab.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: how many prior messages the chat tab sends back to the model.
# Defaults to 6 if unset.
# MESSAGE_WINDOW = 6
